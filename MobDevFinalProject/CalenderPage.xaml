<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MobDevFinalProject.CalenderPage"
             xmlns:vm="clr-namespace:MobDevFinalProject.ViewModels"
             x:DataType="vm:CalenderPageViewModel"
             Title="CalenderPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#111111">
    <VerticalStackLayout Padding="30, 100" Spacing="15">
        <Label 
            Text="Enter Date"
            VerticalOptions="Center" 
            HorizontalOptions="Center"
            TextColor="White"/>
        <DatePicker x:Name="chosenDate" TextColor="White"/>
        <Button
            Text="View or Edit Data" 
            Clicked="Next_Page"
            HorizontalOptions="Fill" 
            BackgroundColor="RoyalBlue"
            TextColor="White"/> 
        <Button
            Text="Back" 
            Clicked="Back_Button"
            HorizontalOptions="Fill" 
            BackgroundColor="RoyalBlue"
            TextColor="White"
            />
        
    </VerticalStackLayout>
</ContentPage>